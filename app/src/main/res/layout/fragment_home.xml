<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:swipeRefreshLayoutProgressSpinnerBackgroundColor="#F5A623">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1C1B1F"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Shimmer Banner Placeholder -->
            <FrameLayout
                android:id="@+id/shimmerBanner"
                android:layout_width="match_parent"
                android:layout_height="480dp"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#2A2A2A" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/indicator_selected" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/indicator_unselected" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginHorizontal="4dp"
                        android:background="@drawable/indicator_unselected" />

                </LinearLayout>

            </FrameLayout>

            <!-- Hero Banner ViewPager2 -->
            <FrameLayout
                android:id="@+id/bannerContainer"
                android:layout_width="match_parent"
                android:layout_height="480dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/viewPagerHero"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- Dot Indicators -->
                <LinearLayout
                    android:id="@+id/indicatorContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal"
                    android:gravity="center" />

            </FrameLayout>

            <!-- Shimmer Popular Placeholder -->
            <include
                android:id="@+id/shimmerPopular"
                layout="@layout/shimmer_section_horizontal"
                android:visibility="gone" />

            <!-- Section: Popular Movies -->
            <include
                android:id="@+id/sectionPopular"
                layout="@layout/item_section_header" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPopular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_movie_card_horizontal" />

            <!-- Shimmer Top Rated Placeholder -->
            <include
                android:id="@+id/shimmerTopRated"
                layout="@layout/shimmer_section_grid"
                android:visibility="gone" />

            <!-- Section: Top Rated This Week -->
            <include
                android:id="@+id/sectionTopRated"
                layout="@layout/item_section_header" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTopRated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/item_movie_card_grid" />

            <!-- Shimmer Recommended Placeholder -->
            <include
                android:id="@+id/shimmerRecommended"
                layout="@layout/shimmer_section_grid"
                android:visibility="gone" />

            <!-- Section: Recommended For You -->
            <include
                android:id="@+id/sectionRecommended"
                layout="@layout/item_section_header" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecommended"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/item_movie_card_grid" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
