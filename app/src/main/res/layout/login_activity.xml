<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:id="@+id/imgBanner"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/background_login_register"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Logo MovieBox -->
    <TextView
        android:id="@+id/moviebox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MovieBox"
        android:textColor="#F5A623"
        android:textStyle="bold"
        android:textSize="28sp"
        android:layout_marginTop="55dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Gạch vàng dưới logo -->
    <View
        android:id="@+id/divider_gold"
        android:layout_width="100dp"
        android:layout_height="3dp"
        android:background="@drawable/divider_gold"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/moviebox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tiêu đề -->
    <TextView
        android:id="@+id/text1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chào mừng trở lại"
        android:textStyle="bold"
        android:textSize="25sp"
        android:textColor="@color/white"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/divider_gold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/text2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đăng nhập để tiếp tục ..."
        android:textSize="12sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/text1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Card Form -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardForm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:padding="20dp"
        android:background="@drawable/bg_card_form"
        app:layout_constraintTop_toBottomOf="@id/text2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Label Email -->
        <TextView
            android:id="@+id/text3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMAIL HOẶC SỐ ĐIỆN THOẠI"
            android:textSize="11sp"
            android:textColor="#aaaaaa"
            android:letterSpacing="0.05"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- EditText Email -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:boxBackgroundColor="#2d2408"
            app:boxStrokeColor="#4a3c10"
            app:boxStrokeWidth="1dp"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            app:startIconTint="#888888"
            app:layout_constraintTop_toBottomOf="@id/text3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="name@example.com"
                android:textColor="#ffffff"
                android:textColorHint="#666666"
                android:inputType="textEmailAddress"
                android:background="@null"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Label + Quên mật khẩu -->
        <TextView
            android:id="@+id/labelPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MẬT KHẨU"
            android:textSize="11sp"
            android:textColor="#aaaaaa"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/tilEmail"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvForgot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quên mật khẩu?"
            android:textSize="11sp"
            android:textColor="#F5A623"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/tilEmail"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- EditText Password -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:boxBackgroundColor="#2d2408"
            app:boxStrokeColor="#4a3c10"
            app:boxStrokeWidth="1dp"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            app:startIconTint="#888888"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#888888"
            app:layout_constraintTop_toBottomOf="@id/labelPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="123456789"
                android:textColor="#ffffff"
                android:textColorHint="#666666"
                android:inputType="textPassword"
                android:background="@null"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Button Đăng nhập -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="Đăng nhập →"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1a1508"
            android:layout_marginTop="20dp"
            app:backgroundTint="#F5A623"
            app:cornerRadius="12dp"
            app:rippleColor="#33000000"
            app:layout_constraintTop_toBottomOf="@id/tilPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Divider HOẶC -->
        <View
            android:id="@+id/lineLeft"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#33ffffff"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvOr"
            app:layout_constraintBaseline_toBaselineOf="@id/tvOr"/>

        <TextView
            android:id="@+id/tvOr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOẶC TIẾP TỤC VỚI"
            android:textSize="10sp"
            android:textColor="#666666"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <View
            android:id="@+id/lineRight"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#33ffffff"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@id/tvOr"
            app:layout_constraintBottom_toBottomOf="@id/tvOr"
            app:layout_constraintStart_toEndOf="@id/tvOr"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Social Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogle"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="Google"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="8dp"
            app:iconTint="@null"
            app:strokeColor="#4a3c10"
            app:cornerRadius="10dp"
            app:backgroundTint="#2d2408" app:layout_constraintTop_toBottomOf="@id/tvOr" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/btnFacebook"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFacebook"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="Facebook"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:layout_marginTop="14dp"
            android:layout_marginStart="8dp"
            app:iconTint="@null"
            app:strokeColor="#4a3c10"
            app:cornerRadius="10dp"
            app:backgroundTint="#2d2408"
            app:layout_constraintTop_toBottomOf="@id/tvOr"
            app:layout_constraintStart_toEndOf="@id/btnGoogle"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Chưa có tài khoản -->
    <TextView
        android:id="@+id/tvRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chưa có tài khoản? Đăng ký ngay"
        android:textSize="13sp"
        android:textColor="#aaaaaa"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardForm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>