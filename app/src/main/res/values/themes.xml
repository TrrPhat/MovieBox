<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MoiveBox" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">#F5A623</item>
        <item name="colorOnPrimary">#1a1508</item>
        <item name="colorPrimaryContainer">#4a3c10</item>
        <item name="colorOnPrimaryContainer">#F5A623</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">#F5A623</item>
        <item name="colorOnSecondary">#1a1508</item>

        <!-- Surface colors -->
        <item name="colorSurface">#1C1B1F</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorSurfaceVariant">#2d2408</item>
        <item name="colorOnSurfaceVariant">#aaaaaa</item>

        <!-- Background -->
        <item name="android:colorBackground">#1C1B1F</item>
        <item name="colorOnBackground">#FFFFFF</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">#1C1B1F</item>
        <item name="android:navigationBarColor">#1C1B1F</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Error -->
        <item name="colorError">#CF6679</item>
        <item name="colorOnError">#000000</item>
    </style>

    <style name="Theme.MoiveBox" parent="Base.Theme.MoiveBox" />
</resources>
